{
  "name": "kutlass-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run kutlass-demo:dev",
    "lint": "nx run-many -t lint",
    "test": "nx run kutlass:test",
    "build:lib": "nx run kutlass:build",
    "build:app": "nx run kutlass-demo:build"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "nx": "^21.3.2",
    "vitest": "^3.1.1"
  }
}
