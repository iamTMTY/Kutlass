{
  "name": "kutlass-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run kutlass-demo:dev",
    "lint": "nx run-many -t lint",
    "build:lib": "nx run kutlass:build",
    "build:app": "nx run kutlass-demo:build"
  },
  "devDependencies": {
    "nx": "^21.3.2"
  }
}
